// SHADER INJECTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Shader injection system using photon
pub struct ShaderManager {
    injector: ShaderInjector,
    shaders: HashMap<u64, ShaderInfo>,
}

pub struct ShaderInfo {
    pub hash: u64,
    pub name: String,
    pub stage: ShaderStage,
    pub original: Vec<u8>,
    pub modified: Option<Vec<u8>>,
}

#[derive(Clone, Copy)]
pub enum ShaderStage {
    Vertex,
    Pixel,
    Compute,
    Geometry,
    Hull,
    Domain,
}

impl ShaderManager {
    pub fn new() -> Self {
        ShaderManager {
            injector: ShaderInjector::new(),
            shaders: HashMap::new(),
        }
    }

    /// Register a shader for potential modification
    pub fn register(&mut self, hash: u64, bytecode: &[u8], stage: ShaderStage) {
        self.shaders.insert(hash, ShaderInfo {
            hash,
            name: format!("shader_{:016x}", hash),
            stage,
            original: bytecode.to_vec(),
            modified: None,
        });
    }

    /// Inject a modified shader
    pub fn inject(&mut self, hash: u64, modified: Vec<u8>) -> Result<(), String> {
        if let Some(shader) = self.shaders.get_mut(&hash) {
            shader.modified = Some(modified.clone());
            self.injector.inject(hash, &modified)?;
            Ok(())
        } else {
            Err(format!("Shader {:016x} not found", hash))
        }
    }

    /// List all registered shaders
    pub fn list_shaders(&self) -> Vec<&ShaderInfo> {
        self.shaders.values().collect()
    }
}

