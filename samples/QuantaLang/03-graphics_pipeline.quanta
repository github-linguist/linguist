// COLOR PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

/// Color science pipeline using spectrum and chromatic modules
pub struct ColorPipeline {
    working_space: ColorSpace,
    output_space: OutputColorSpace,
    lut: Option<LUT3D>,
    gamut_mapper: GamutMapping,
}

impl ColorPipeline {
    pub fn new(output_space: OutputColorSpace) -> Self {
        // Use OKLab as working space for perceptual uniformity
        let working_space = ColorSpace::OKLab;

        // Setup gamut mapping for output
        let gamut = match output_space {
            OutputColorSpace::SRGB => Gamut::SRGB,
            OutputColorSpace::DisplayP3 => Gamut::DisplayP3,
            OutputColorSpace::Rec2020 => Gamut::Rec2020,
            OutputColorSpace::ACES => Gamut::ACES,
        };

        ColorPipeline {
            working_space,
            output_space,
            lut: None,
            gamut_mapper: GamutMapping::new(gamut),
        }
    }

    /// Load a 3D LUT for color grading
    pub fn load_lut(&mut self, path: &str) -> Result<(), String> {
        self.lut = Some(LUT3D::load(path)?);
        Ok(())
    }

    /// Transform frame colors
    pub fn transform(&self, mut frame: Frame) -> Frame {
        // Apply LUT if present
        if let Some(ref lut) = self.lut {
            frame = self.apply_lut(frame, lut);
        }

        // Gamut mapping to output space
        frame = self.map_gamut(frame);

        frame
    }

    fn apply_lut(&self, frame: Frame, lut: &LUT3D) -> Frame {
        // Apply 3D LUT to each pixel
        frame.map_pixels(|rgb| {
            lut.lookup(rgb)
        })
    }

    fn map_gamut(&self, frame: Frame) -> Frame {
        frame.map_pixels(|rgb| {
            self.gamut_mapper.map(rgb)
        })
    }
}

/// Color analysis utilities
pub struct ColorAnalyzer;

impl ColorAnalyzer {
    /// Calculate perceptual color difference using DeltaE 2000
    pub fn color_difference(c1: &RGB, c2: &RGB) -> f64 {
        let lab1 = c1.to_oklab();
        let lab2 = c2.to_oklab();
        DeltaE::delta_e_2000(&lab1, &lab2)
    }

    /// Find the most perceptually distinct colors in a palette
    pub fn find_distinct_colors(colors: &[RGB], count: usize) -> Vec<RGB> {
        let mut selected = Vec::new();
        let mut remaining: Vec<RGB> = colors.to_vec();

        // Start with first color
        if let Some(first) = remaining.pop() {
            selected.push(first);
        }

        // Greedily select most distinct colors
        while selected.len() < count && !remaining.is_empty() {
            let mut best_idx = 0;
            let mut best_min_dist = 0.0;

            for (i, candidate) in remaining.iter().enumerate() {
                let min_dist = selected.iter()
                    .map(|s| Self::color_difference(candidate, s))
                    .fold(f64::INFINITY, f64::min);

                if min_dist > best_min_dist {
                    best_min_dist = min_dist;
                    best_idx = i;
                }
            }

            selected.push(remaining.remove(best_idx));
        }

        selected
    }

    /// Generate a perceptually uniform gradient
    pub fn uniform_gradient(start: RGB, end: RGB, steps: usize) -> Vec<RGB> {
        let start_lab = start.to_oklab();
        let end_lab = end.to_oklab();

        (0..steps).map(|i| {
            let t = i as f64 / (steps - 1) as f64;
            let lab = OKLab::lerp(&start_lab, &end_lab, t);
            lab.to_rgb()
        }).collect()
    }
}

