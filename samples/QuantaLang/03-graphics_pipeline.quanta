}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════════════════════════

fn main() {
    println!("╔═══════════════════════════════════════════════════════════════╗");
    println!("║  Graphics Pipeline Demo                                       ║");
    println!("║  Powered by QUANTA-UNIVERSE                                   ║");
    println!("╚═══════════════════════════════════════════════════════════════╝");
    println!();

    // Configure the pipeline
    let config = PipelineConfig {
        resolution: (3840, 2160),  // 4K output
        render_scale: 0.5,         // Render at 1080p
        hdr_enabled: true,
        upscaling: UpscaleMethod::DLSS,
        color_space: OutputColorSpace::DisplayP3,
        post_effects: vec![
            "bloom".to_string(),
            "tonemapping".to_string(),
            "color_grading".to_string(),
            "taa".to_string(),
        ],
    };

    // Create pipeline
    let mut pipeline = GraphicsPipeline::new(config);
    println!();

    // Demo: Color analysis
    println!("─────────────────────────────────────────────────────────────────");
    println!("Color Science Demo (Spectrum + Chromatic)");
    println!("─────────────────────────────────────────────────────────────────");

    let red = RGB::new(255, 0, 0);
    let orange = RGB::new(255, 165, 0);
    let diff = ColorAnalyzer::color_difference(&red, &orange);
    println!("  Delta E between red and orange: {:.2}", diff);

    let gradient = ColorAnalyzer::uniform_gradient(red, RGB::new(0, 0, 255), 5);
    println!("  Perceptual gradient: {} colors", gradient.len());

    // Demo: Create a test scene
    let scene = Scene {
        name: "Test Scene".to_string(),
        objects: 1000,
        lights: 8,
    };

    println!();
    println!("─────────────────────────────────────────────────────────────────");
    println!("Rendering Demo (Photon + Lumina + Neutrino)");
    println!("─────────────────────────────────────────────────────────────────");

    // Render a frame
    let _frame = pipeline.render_frame(&scene);

    println!();
    println!("─────────────────────────────────────────────────────────────────");
    println!("Pipeline Statistics");
    println!("─────────────────────────────────────────────────────────────────");
    println!("  Frames rendered: {}", pipeline.stats.frames_rendered);
    println!("  Draw calls: {}", pipeline.stats.draw_calls);

    println!();
    println!("═══════════════════════════════════════════════════════════════════");
    println!("  Graphics Pipeline demo complete!");
    println!("═══════════════════════════════════════════════════════════════════");
}
