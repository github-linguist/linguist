// Bloom Language — Variables and Math example
fn main() {
    let x = 10
    let y = 20
    let sum = x + y
    let product = x * y

    print("x =")
    print(x)
    print("y =")
    print(y)
    print("x + y =")
    print(sum)
    print("x * y =")
    print(product)
    print("x % 3 =")
    print(x % 3)
}
