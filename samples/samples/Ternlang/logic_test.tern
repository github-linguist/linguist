// Ternlang Logic & Sparse Inference Example
// Part of the Ternary Intelligence Stack for the BET VM

@sparseskip
fn consensus(a: trit, b: trit) -> trit {
    // The compiler enforces exhaustiveness for the 0 state
    match a {
        +1 => {
            match b {
                +1 => return +1,
                0  => return +1,
                -1 => return 0,
            }
        }
        0 => {
            return b;
        }
        -1 => {
            match b {
                +1 => return 0,
                0  => return -1,
                -1 => return -1,
            }
        }
    }
}

pub fn main() {
    let input_a: trit = +1;
    let input_b: trit = 0;
    
    let result = consensus(input_a, input_b);
    
    // Output is routed to the albert-agent or CLI
    println!("Ternary Consensus: {}", result);
}
